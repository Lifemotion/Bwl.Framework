<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Width="400"
        Height="300"
        Title="Log Info"
        x:Class="Bwl.Framework.Avalonia.FormLogInfo">
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>
		<TextBox Name="LogInfoTextBox"
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 VerticalAlignment="Stretch"
                 HorizontalAlignment="Stretch"
                 VerticalContentAlignment="Top"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
			     Margin="10"
			     Grid.Row="0"
                 Padding="10"/>
		<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="1">
			<Button Name="CopyTextButton" Content="Copy Text" Margin="5" Click="CopyTextButton_Click"/>
			<Button Name="CloseButton" Content="Close" Margin="5" Click="CloseButton_Click"/>
		</StackPanel>
	</Grid>
</Window>
