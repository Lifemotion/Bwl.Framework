<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="884" d:DesignHeight="510"
        x:Class="Bwl.Network.ClientServer.Avalonia.CmdlineUi"
        Title="CmdlineUi">
	<Viewbox Stretch="Uniform">
		<Canvas Width="884" Height="493">
			<ComboBox Name="cbInput" Width="870" Canvas.Left="6" Canvas.Top="469"/>

			<CheckBox Name="cbAlive" Content="Alive" Height="17" Canvas.Left="8"/>
			<CheckBox Name="cbResponding" Content="Responding" Height="17" Canvas.Left="73" />
			<CheckBox Name="cbHasExited" Content="HasExited" Canvas.Left="297"/>
			<CheckBox Name="cbHasStarted" Content="HasStarted" Height="17" Canvas.Left="182" />
			<CheckBox Name="cbFilter" Content="Filter" Height="17" Canvas.Left="700"/>

			<TextBox Name="TextBox1" Width="880" Height="434" Canvas.Left="2" Canvas.Top="32"/>
			<TextBox Name="tbFilter" Width="100" Height="20" Canvas.Left="772" Canvas.Top="4"/>

			<Button Name="bClear" Content="Clear" Width="75" Height="25" Canvas.Top="3" Canvas.Left="620"/>

		</Canvas>
	</Viewbox>
</Window>
