<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="505" d:DesignHeight="230"
        x:Class="Bwl.Network.ClientServer.Avalonia.NetworkAdaptersForm"
        Title="NetworkAdaptersForm">
	<Viewbox Stretch="Uniform">
		<Canvas Width="505" Height="230">
			<Button Name="bOK" Canvas.Left="418" Canvas.Top="195" Width="75" Content="OK"/>
			<Button Name="bCancel" Canvas.Left="337" Canvas.Top="195" Width="75" Content="Cancel"/>
			<ListBox Name="lbAdapters" Canvas.Left="12" Canvas.Top="12" Width="481" Height="173" />
		</Canvas>
	</Viewbox>
</Window>
