<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Bwl.Framework.Avalonia;assembly=Bwl.Framework.Avalonia"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
		Width="800" Height="600"
        x:Class="Bwl.Framework.Avalonia.AutoUIForm"
        Title="AutoUiform">
	<local:FormBase x:Name="FormBase">
		<local:FormBase.FormContent>
			<local:AutoUIDisplay x:Name="AutoUIDisplay1"
								 AutoFormDescriptorUpdated="AutoFormDescriptorUpdated" />
		</local:FormBase.FormContent>
	</local:FormBase>
</Window>
